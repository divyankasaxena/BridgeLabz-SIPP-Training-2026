class HeapSort {

    // Heap Sort Function
    public static void heapSort(int[] arr) {
        int n = arr.length;

        // Step 1: Build Max Heap
        for (int i = n / 2 - 1; i >= 0; i--) {
            siftDownMax(arr, i, n);
        }

        // Step 2: Extract elements one by one
        for (int end = n - 1; end > 0; end--) {

            // Move current maximum to the end
            int temp = arr[0];
            arr[0] = arr[end];
            arr[end] = temp;

            // Restore Max Heap for the remaining elements
            siftDownMax(arr, 0, end);
        }
    }

    // Heapify (Sift Down) for Max Heap
    public static void siftDownMax(int[] arr, int i, int size) {

        int largest = i;
        int left = 2 * i + 1;
        int right = 2 * i + 2;

        if (left < size && arr[left] > arr[largest]) {
            largest = left;
        }

        if (right < size && arr[right] > arr[largest]) {
            largest = right;
        }

        if (largest != i) {
            int temp = arr[i];
            arr[i] = arr[largest];
            arr[largest] = temp;

            siftDownMax(arr, largest, size);
        }
    }

    // Print Array
    public static void printArray(int[] arr) {
        for (int num : arr) {
            System.out.print(num + " ");
        }
        System.out.println();
    }

    public static void main(String[] args) {

        int[] readings = {40, 10, 30, 50, 60, 15, 20};

        System.out.println("Original Array:");
        printArray(readings);

        heapSort(readings);

        System.out.println("Sorted Array:");
        printArray(readings);
    }
}
