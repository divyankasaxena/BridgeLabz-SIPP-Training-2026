import java.util.*;

public class Solution {

    public List<List<String>> generateSchedules(String[] engineers) {
        List<List<String>> ans = new ArrayList<>();
        boolean[] used = new boolean[engineers.length];
        dfs(engineers, used, new ArrayList<>(), ans);
        return ans;
    }

    private void dfs(String[] engineers, boolean[] used, List<String> cur, List<List<String>> ans) {
        if (cur.size() == engineers.length) {
            ans.add(new ArrayList<>(cur));
            return;
        }

        for (int i = 0; i < engineers.length; i++) {
            if (used[i])
                continue;

            used[i] = true;
            cur.add(engineers[i]);

            dfs(engineers, used, cur, ans);

            cur.remove(cur.size() - 1);
            used[i] = false;
        }
    }
}
