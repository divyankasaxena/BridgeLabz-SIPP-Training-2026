class InterviewBot {

    // Instance variables
    private String botName;
    private String technology;

    // Constructor
    public InterviewBot(String botName, String technology) {
        this.botName = botName;         // this resolves ambiguity
        this.technology = technology;
    }

    // Method
    public void conductInterview() {
        System.out.println(botName +
                " is conducting a " +
                technology + " interview.");
    }
}

public class AIInterviewBot {
    public static void main(String[] args) {

        // Creating 3 interview bots
        InterviewBot bot1 = new InterviewBot("CodeMaster", "Java");
        InterviewBot bot2 = new InterviewBot("WebExpert", "React");
        InterviewBot bot3 = new InterviewBot("DataGuru", "Python");

        // Conducting interviews
        bot1.conductInterview();
        bot2.conductInterview();
        bot3.conductInterview();
    }
}
