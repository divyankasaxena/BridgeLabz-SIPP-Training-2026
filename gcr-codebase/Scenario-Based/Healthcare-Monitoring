interface HeartRateMonitor {

    void showHeartRate(int heartRate);

    default void displayHealthTips() {
        System.out.println("Tip: Exercise regularly for a healthy heart.");
    }
}

interface TemperatureMonitor {

    void showTemperature(double temperature);

    default void displayHealthTips() {
        System.out.println("Tip: Drink plenty of water and stay hydrated.");
    }

    static boolean isPatientIdValid(String patientId) {
        return patientId.length() == 6;
    }
}

class HealthMonitoringSystem implements HeartRateMonitor, TemperatureMonitor {

    public void showHeartRate(int heartRate) {
        System.out.println("Heart Rate : " + heartRate + " bpm");
    }

    public void showTemperature(double temperature) {
        System.out.println("Temperature : " + temperature + " °C");
    }

    public void displayHealthTips() {
        HeartRateMonitor.super.displayHealthTips();
        TemperatureMonitor.super.displayHealthTips();
    }
}

public class Main {
    public static void main(String[] args) {

        String[] names = {"Rahul", "Priya", "Aman", "Neha"};
        String[] ids = {"P10001", "P200", "P30003", "P40004"};
        int[] heartRates = {72, 88, 95, 70};
        double[] temperatures = {36.8, 37.5, 38.2, 36.6};

        HealthMonitoringSystem system = new HealthMonitoringSystem();

        system.displayHealthTips();

        System.out.println();

        for (int i = 0; i < names.length; i++) {

            System.out.println("Patient : " + names[i]);

            if (TemperatureMonitor.isPatientIdValid(ids[i])) {
                System.out.println("Patient ID : " + ids[i] + " (Valid)");
            } else {
                System.out.println("Patient ID : " + ids[i] + " (Invalid)");
            }

            system.showHeartRate(heartRates[i]);
            system.showTemperature(temperatures[i]);

            if (TemperatureMonitor.isPatientIdValid(ids[i])) {
                System.out.println("Health Report : Record Accepted");
            } else {
                System.out.println("Health Report : Record Rejected");
            }

            System.out.println();
        }
    }
}
