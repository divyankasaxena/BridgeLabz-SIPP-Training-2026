import java.util.*;

public class Solution {

    public List<List<Integer>> allPaths(Map<Integer, List<Integer>> roads, int source, int target) {
        List<List<Integer>> ans = new ArrayList<>();
        List<Integer> path = new ArrayList<>();
        Set<Integer> vis = new HashSet<>();

        dfs(roads, source, target, vis, path, ans);

        return ans;
    }

    private void dfs(Map<Integer, List<Integer>> roads, int cur, int target,
                     Set<Integer> vis, List<Integer> path, List<List<Integer>> ans) {

        vis.add(cur);
        path.add(cur);

        if (cur == target) {
            ans.add(new ArrayList<>(path));
        } else {
            for (int next : roads.getOrDefault(cur, new ArrayList<>())) {
                if (!vis.contains(next)) {
                    dfs(roads, next, target, vis, path, ans);
                }
            }
        }

        path.remove(path.size() - 1);
        vis.remove(cur);
    }
}
