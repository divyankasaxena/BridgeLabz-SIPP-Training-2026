import java.util.*;

public class Solution {

    public boolean hasCycle(Map<Integer, List<Integer>> graph, int n) {
        boolean[] vis = new boolean[n];
        boolean[] path = new boolean[n];

        for (int i = 0; i < n; i++) {
            if (!vis[i]) {
                if (dfs(graph, i, vis, path))
                    return true;
            }
        }

        return false;
    }

    private boolean dfs(Map<Integer, List<Integer>> graph, int node, boolean[] vis, boolean[] path) {
        vis[node] = true;
        path[node] = true;

        for (int next : graph.getOrDefault(node, new ArrayList<>())) {
            if (!vis[next]) {
                if (dfs(graph, next, vis, path))
                    return true;
            } else if (path[next]) {
                return true;
            }
        }

        path[node] = false;
        return false;
    }
}
