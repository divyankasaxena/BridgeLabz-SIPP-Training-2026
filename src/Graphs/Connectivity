import java.util.*;

public class Solution {

    public int countNetworkSegments(Map<Integer, List<Integer>> network, int n) {
        Set<Integer> vis = new HashSet<>();
        int segments = 0;

        for (int i = 0; i < n; i++) {
            if (!vis.contains(i)) {
                dfs(network, i, vis);
                segments++;
            }
        }

        return segments;
    }

    private void dfs(Map<Integer, List<Integer>> network, int node, Set<Integer> vis) {
        vis.add(node);

        for (int next : network.getOrDefault(node, new ArrayList<>())) {
            if (!vis.contains(next)) {
                dfs(network, next, vis);
            }
        }
    }
}
