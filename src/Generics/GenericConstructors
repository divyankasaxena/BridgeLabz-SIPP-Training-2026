class Box<T> {

    private T value;

    public <U> Box(U input, T value) {
        System.out.println("Input: " + input);
        this.value = value;
    }

    public void display() {
        System.out.println("Value: " + value);
    }
}

public class GenericConstructorExample {

    public static void main(String[] args) {

        Box<String> box1 = new Box<>(100, "Java");
        box1.display();

        Box<Integer> box2 = new Box<>("Hello", 50);
        box2.display();
    }
}
