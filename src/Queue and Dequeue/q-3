import java.util.PriorityQueue;

class Patient {
    int priority;
    String name;

    public Patient(int priority, String name) {
        this.priority = priority;
        this.name = name;
    }
}

public class HospitalER {

    // Min-Heap based on priority
    private PriorityQueue<Patient> triageQueue;

    // Constructor
    public HospitalER() {
        triageQueue = new PriorityQueue<>((a, b) -> a.priority - b.priority);
    }

    // Admit a patient
    public void admitPatient(Patient p) {
        triageQueue.offer(p);
    }

    // Call the most urgent patient
    public Patient callNextPatient() {
        if (triageQueue.isEmpty()) {
            throw new RuntimeException("No patients waiting");
        }
        return triageQueue.poll();
    }

    // View the most urgent patient
    public Patient peekNextPatient() {
        if (triageQueue.isEmpty()) {
            throw new RuntimeException("No patients waiting");
        }
        return triageQueue.peek();
    }

    // Display all waiting patients
    public void display() {
        if (triageQueue.isEmpty()) {
            System.out.println("No patients waiting");
            return;
        }

        System.out.println("Waiting Patients:");
        for (Patient p : triageQueue) {
            System.out.println("Priority: " + p.priority + "  Name: " + p.name);
        }
    }

    // Main Method
    public static void main(String[] args) {

        HospitalER er = new HospitalER();

        er.admitPatient(new Patient(3, "Rahul"));
        er.admitPatient(new Patient(1, "Amit"));
        er.admitPatient(new Patient(2, "Neha"));
        er.admitPatient(new Patient(5, "Priya"));

        System.out.println("Next Patient: "
                + er.peekNextPatient().name
                + " (Priority " + er.peekNextPatient().priority + ")");

        Patient p = er.callNextPatient();
        System.out.println("Treating: " + p.name);

        er.display();
    }
}
